# Database Configuration
# For SQLite (development):
# DATABASE_URL="file:./dev.db"
# For PostgreSQL (production):
DATABASE_URL="postgresql://saasrabota:saasrabota_secret@localhost:5432/saasrabota"

# PostgreSQL Docker Configuration
POSTGRES_USER="saasrabota"
POSTGRES_PASSWORD="saasrabota_secret"
POSTGRES_DB="saasrabota"
POSTGRES_PORT="5432"

# Redis Configuration
REDIS_URL="redis://:redis_secret@localhost:6379"
REDIS_PASSWORD="redis_secret"
REDIS_PORT="6379"

# NextAuth Configuration
NEXTAUTH_SECRET="your-super-secret-key-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# Encryption Key for sensitive data (32 bytes hex string)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY="your-32-byte-encryption-key-hex-string"

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"

# Application Port
APP_PORT="3000"